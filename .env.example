# ============================================================
#  SyliGo — Serveur d'envoi SMS
#  Copie ce fichier en ".env" et remplis tes valeurs.
# ============================================================

PORT=8080

# Clé secrète qui protège ton serveur. Mets une longue valeur au hasard.
# L'app SyliGo devra l'envoyer dans l'en-tête "x-api-key".
API_KEY=change-moi-par-une-longue-cle-secrete

# Quelle passerelle utiliser : console | nimba | orange | twilio | whatsapp
#  - console  : n'envoie rien, affiche juste le message (pour TESTER gratuitement)
#  - nimba    : Nimba SMS (Guinée)
#  - orange   : API Orange SMS
#  - twilio   : Twilio (international)
#  - whatsapp : WhatsApp Cloud API (souvent moins cher en data)
SMS_PROVIDER=console

# Limite anti-abus : envois max par minute (protège ton crédit)
RATE_MAX=60


# Nom court de l'expéditeur (selon ce qui est autorisé par la passerelle)
SMS_SENDER=SYLIGO

# --- Nimba SMS (https://nimbasms.com) ------------------------
# Récupère ces valeurs dans ton tableau de bord Nimba > API.
NIMBA_SERVICE_ID=
NIMBA_SECRET_TOKEN=
NIMBA_BASE_URL=https://api.nimbasms.com/v1

# --- API Orange SMS (https://developer.orange.com) -----------
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
# Le numéro expéditeur fourni par Orange, au format tel:+224XXXXXXXX
ORANGE_SENDER_ADDRESS=tel:+224000000000

# --- Twilio (https://twilio.com) -----------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+10000000000

# --- WhatsApp Cloud API (https://developers.facebook.com) ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v21.0
